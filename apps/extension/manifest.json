{
	"manifest_version": 3,
	"name": "BridgeHook",
	"description": "Forward webhooks from the cloud to your localhost — no CLI, no tunnel, no install.",
	"version": "0.1.0",
	"permissions": ["storage", "notifications", "offscreen", "alarms"],
	"host_permissions": [
		"http://localhost:*/*",
		"https://relay.bridgehook.dev/*",
		"https://bridgehook-relay.halleluyaholudele.workers.dev/*",
		"https://bridgehook-web.pages.dev/*",
		"https://app.bridgehook.dev/*"
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"32": "icons/icon-32.png"
		}
	},
	"icons": {
		"32": "icons/icon-32.png",
		"128": "icons/icon-128.png"
	}
}
